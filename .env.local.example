# X (Twitter) — browser automation (self-managed Chromium)
#
# First-time login:
#   1. Start the container: docker compose up -d
#   2. Open the Chrome DevTools endpoint: http://127.0.0.1:18810/json
#      OR use a remote debugger to connect and navigate to x.com
#   3. Log into X manually in the browser
#   4. Session is saved in ./data/chrome-profile — no re-login needed after restart
#
# To use an already-running browser (e.g. OpenClaw) instead:
#   X_CDP_URL=http://127.0.0.1:18800

# Uncomment to run headful (needs DISPLAY on host):
# X_HEADLESS=false

# Post pacing (ms between tweets)
X_POST_DELAY_MS=3000

# x-bot — MiniMax LLM content generation
# Get key from: https://platform.minimax.io
MINIMAX_API_KEY=
# MINIMAX_MODEL=MiniMax-M2.5-highspeed
# XBOT_LANGUAGE=auto   # zh | en | auto
